# ── Veritabanı ──────────────────────────────────────────────────────────────
DB_USER=timesheet
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=timesheet

# ── JWT Sırları (openssl rand -hex 64 ile üret) ───────────────────────────
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET

# ── SMTP Mail ────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@example.com
MAIL_PASS=your_smtp_password
MAIL_FROM=Timesheet <noreply@example.com>

# ── URL'ler ──────────────────────────────────────────────────────────────────
# Backend: Docker Compose'da service adıyla ulaşılır, dışarıdan erişim için alan adı
FRONTEND_URL=https://timesheet.example.com
VITE_API_URL=https://timesheet.example.com/api
